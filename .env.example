# Copy this file to ".env" and fill in real values.
# ".env" is gitignored and must NEVER be committed.

# ---------- PostgreSQL ----------
POSTGRES_USER=cryptopal
POSTGRES_PASSWORD=change_me
POSTGRES_DB=cryptopal
POSTGRES_PORT=5432

# ---------- Redis ----------
REDIS_PORT=6379

# ---------- CryptoPal Core (Spring Boot) ----------
SERVER_PORT=8080
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/cryptopal
SPRING_DATASOURCE_USERNAME=cryptopal
SPRING_DATASOURCE_PASSWORD=change_me
SPRING_REDIS_HOST=localhost
SPRING_REDIS_PORT=6379

# ---------- External Data Provider ----------
# active profile: "ticker" (local simulator) or "live" (external API)
DATA_PROVIDER_PROFILE=ticker

# ---------- LLM (Google Gemini) ----------
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash
